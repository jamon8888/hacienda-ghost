# --- LiteLLM (self-hosted proxy) ---
# Base URL of your self-hosted LiteLLM proxy (OpenAI-compatible endpoint).
LITELLM_BASE_URL=http://localhost:4000
# Virtual key or master key configured in your LiteLLM proxy.
LITELLM_API_KEY=sk-litellm-your-key
# Model name as registered in your LiteLLM proxy config.
# The "openai/" prefix tells the LiteLLM client to use the OpenAI-compatible
# adapter when talking to the proxy.
LITELLM_MODEL=openai/gpt-5.4-mini
