{
  "mcpServers": {
    "hacienda": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "piighost", "piighost", "serve", "--transport", "stdio"],
      "env": {
        "HACIENDA_DATA_DIR": "${HOME}/.hacienda",
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8"
      }
    }
  }
}
